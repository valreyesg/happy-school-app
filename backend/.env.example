# Base de datos
DATABASE_URL=postgresql://usuario:contraseña@localhost:5432/happy_school

# JWT
JWT_SECRET=cambia_esto_por_un_secreto_seguro_de_64_caracteres
JWT_REFRESH_SECRET=cambia_esto_por_otro_secreto_seguro_de_64_caracteres
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Servidor
PORT=3000
NODE_ENV=development

# Cloudinary
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# Firebase (push notifications)
FIREBASE_PROJECT_ID=tu_proyecto
FIREBASE_PRIVATE_KEY="tu_private_key"
FIREBASE_CLIENT_EMAIL=tu_client_email

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=tu_account_sid
TWILIO_AUTH_TOKEN=tu_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Google Calendar
GOOGLE_CLIENT_ID=tu_client_id
GOOGLE_CLIENT_SECRET=tu_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/callback

# App URL
APP_URL=http://localhost:3000
WEB_URL=http://localhost:5173
